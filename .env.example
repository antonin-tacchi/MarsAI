# ── Docker / Ports ───────────────────────────────────────────────────────────
BACKEND_PORT=5001
MYSQL_PORT=3309
MYSQL_ROOT_PASSWORD=rootpassword

# ── Base de données ───────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=rootpassword

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: changer cette valeur avant la mise en ligne !
JWT_SECRET=changez-cette-valeur-en-production-minimum-32-caracteres

# ── Frontend ─────────────────────────────────────────────────────────────────
# Pas de trailing slash (sinon double slash dans les liens email)
VITE_API_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173

# ── CORS ─────────────────────────────────────────────────────────────────────
# Pas de trailing slash (sinon le browser est bloqué)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Scaleway Object Storage ───────────────────────────────────────────────────
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud
SCALEWAY_BUCKET_NAME=
SCALEWAY_REGION=fr-par
SCALEWAY_FOLDER=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@votredomaine.com
# En dev, redirige tous les emails vers cette adresse
RESEND_DEV_RECIPIENT=votre@email.com
